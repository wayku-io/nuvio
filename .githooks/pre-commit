#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

bash scripts/sync-home.sh
bash scripts/sync-changelog.sh
bash scripts/sync-aiometadata.sh

git add \
  README.md \
  docs/index.md \
  docs/guide/Changelog.md \
  templates/AIOMetadata.json \
  templates/AIOMetadata-Catalogs.json \
  templates/AIOMetadata-All.json \
  templates/AIOMetadata-All-Catalogs.json
